# OpenClaw gateway WebSocket URL (default: local docker-compose setup)
OPENCLAW_GATEWAY_URL=ws://localhost:18789

# OpenClaw gateway auth token (generate with: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
VITE_OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Featherless API key from https://featherless.ai
FEATHERLESS_API_KEY=your-featherless-api-key-here

# ElevenLabs API key for voice input (Scribe Realtime) — https://elevenlabs.io
VITE_ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
